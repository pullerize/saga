# Копия для продакшена. На VPS создать файл .env в корне проекта и заполнить значения.

# Путь к SQLite-файлу. Путь относительный — от корня рабочего каталога приложения.
# Убедись, что папка существует и доступна пользователю, от которого запущен PM2.
DATABASE_URL="file:./prisma/prod.db"

# СЕКРЕТ для NextAuth. Сгенерировать: `openssl rand -base64 32`
AUTH_SECRET="ОБЯЗАТЕЛЬНО_СМЕНИ_МЕНЯ_на_случайную_строку"

# Публичный адрес сайта (https://)
NEXTAUTH_URL="https://saga-group.uz"

# Порт, на котором слушает Next.js (PM2 и Nginx ориентируются на него).
PORT=3000

# Режим NODE
NODE_ENV=production
